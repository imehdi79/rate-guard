# =============================================================================
# Deploy configuration for the root docker-compose.yml (VPS behind Traefik).
# Copy to .env (gitignored) on the VPS and fill in the secrets.
# =============================================================================

# --- Secrets (required — compose refuses to start without them) --------------
POSTGRES_PASSWORD=change-me
ADMIN_API_KEY=change-me-admin-key

# --- Domains (Cloudflare DNS records must point these at the VPS) ------------
# Single-level subdomains so Cloudflare's universal certificate covers them.
DASHBOARD_DOMAIN=rate-guard.mehdify.com
API_DOMAIN=rate-guard-api.mehdify.com

# --- Traefik integration (match your existing Traefik setup) ------------------
# Values below match the mehdify.com VPS Traefik (verified 2026-07-05: network
# "web", resolver "le" with the HTTP-01 challenge, entrypoint "websecure").
# On a different host, read them from the running Traefik's static config.
# Docker network your Traefik container is attached to:
TRAEFIK_NETWORK=web
# Entrypoint name for HTTPS in your Traefik static config:
TRAEFIK_ENTRYPOINT=websecure
# Certificate resolver name from your Traefik static config:
TRAEFIK_CERT_RESOLVER=le

# --- Optional ------------------------------------------------------------------
# Browser origins allowed to call the API cross-origin (comma separated).
# Empty/unset = none (fail closed). The dashboard needs no entry — its
# Next.js proxy calls the API server-side over the compose network.
CORS_ORIGINS=https://rate-guard.mehdify.com

# Postgres identity (defaults shown):
#POSTGRES_USER=rate_guard
#POSTGRES_DB=rate_guard

# Server log level: trace | debug | info | warn | error | fatal
#LOG_LEVEL=info
