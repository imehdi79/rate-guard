# Copy to .env (gitignored) and fill in real values.
# Secrets are injected at runtime — never baked into Docker images.

# --- App ---------------------------------------------------------------------
# Native dev port. 3001 by convention: the Next.js dashboard dev server owns
# 3000, and its proxy defaults to http://localhost:3001. Under docker compose
# this value maps the host port; the container port stays fixed at 3000.
PORT=3001

# Admin API key for /api/admin/* (x-admin-key header). Separate from tenant
# api keys on purpose; unset = admin API disabled (requests are denied).
ADMIN_API_KEY=change-me-admin-key

# --- Logging (pino) ----------------------------------------------------------
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Human-readable one-line logs (dev only — pino-pretty is a devDependency and
# is not installed in the production image; keep false there):
LOG_PRETTY=false

# --- Postgres (used by docker-compose to provision the db service and to
#     construct DATABASE_URL for the migrate/server containers) ---------------
POSTGRES_USER=rate_guard
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rate_guard
# Host port the compose db service is published on:
POSTGRES_PORT=5432

# --- Redis (compose wires REDIS_URL to the redis service automatically;
#     this value is for running natively, outside Docker) ---------------------
REDIS_URL=redis://localhost:6379/0
# Host port the compose redis service is published on:
REDIS_PORT=6379

# --- Prisma (used when running natively, outside Docker: `bunx nx serve`,
#     `bunx prisma migrate dev`, ...) -----------------------------------------
DATABASE_URL=postgresql://rate_guard:change-me@localhost:5432/rate_guard
