# Copy to .env (gitignored) and fill in real values.
# Secrets are injected at runtime — never baked into Docker images.

# --- App ---------------------------------------------------------------------
PORT=3000

# --- Postgres (used by docker-compose to provision the db service and to
#     construct DATABASE_URL for the migrate/server containers) ---------------
POSTGRES_USER=rate_guard
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rate_guard
# Host port the compose db service is published on:
POSTGRES_PORT=5432

# --- Prisma (used when running natively, outside Docker: `bunx nx serve`,
#     `bunx prisma migrate dev`, ...) -----------------------------------------
DATABASE_URL=postgresql://rate_guard:change-me@localhost:5432/rate_guard
