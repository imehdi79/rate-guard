{
  "name": "@rate-guard/server-e2e",
  "version": "0.0.1",
  "private": true,
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0"
  },
  "nx": {
    "implicitDependencies": [
      "@rate-guard/server"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "dependsOn": [
          "@rate-guard/server:build",
          "@rate-guard/server:serve"
        ],
        "options": {
          "jestConfig": "apps/server-e2e/jest.config.cts",
          "passWithNoTests": true
        }
      }
    }
  }
}
