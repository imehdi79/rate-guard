# Base URL of the rate-guard NestJS API the dashboard proxies to.
RATE_GUARD_API_URL=http://localhost:3001

# Demo setup: the admin key lives server-side in the Next.js route handlers
# (never NEXT_PUBLIC_, so it is not shipped to the browser). Must match the
# ADMIN_API_KEY configured for apps/server.
ADMIN_API_KEY=dev-admin-key
